{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/invalid_event_v1.json",
  "title": "Invalid Event v1",
  "description": "Dead-letter event published to market.events.invalid for malformed, invalid, or unroutable payloads.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "source_topic",
    "error_type",
    "error_message",
    "raw_payload",
    "error_time"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "source_topic": {
      "type": "string",
      "enum": [
        "market.trades.raw",
        "market.klines.raw",
        "market.tickers.raw",
        "unknown"
      ]
    },
    "error_type": {
      "type": "string",
      "enum": [
        "VALIDATION_ERROR",
        "JSON_DECODE_ERROR",
        "SCHEMA_ERROR",
        "ROUTING_ERROR",
        "PRODUCER_ERROR"
      ]
    },
    "error_message": {
      "type": "string",
      "minLength": 1
    },
    "raw_payload": {
      "type": "string",
      "minLength": 1
    },
    "error_time": {
      "type": "string",
      "format": "date-time"
    },
    "symbol": {
      "type": "string",
      "pattern": "^[A-Z0-9]{5,20}$",
      "description": "Optional symbol when it can be safely extracted from the raw payload."
    }
  },
  "examples": [
    {
      "schema_version": "1.0",
      "source_topic": "market.trades.raw",
      "error_type": "VALIDATION_ERROR",
      "error_message": "price is missing or invalid",
      "raw_payload": "{\"symbol\":\"BTCUSDT\",\"quantity\":\"0.005\"}",
      "error_time": "2026-04-30T10:20:00Z",
      "symbol": "BTCUSDT"
    }
  ]
}
