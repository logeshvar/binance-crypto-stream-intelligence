# Local service ports
KAFKA_UI_PORT=8080

# Kafka bootstrap servers
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_INTERNAL_BOOTSTRAP_SERVERS=kafka:9092

# Kafka topics
TOPIC_TRADES_RAW=market.trades.raw
TOPIC_KLINES_RAW=market.klines.raw
TOPIC_TICKERS_RAW=market.tickers.raw
TOPIC_EVENTS_INVALID=market.events.invalid
TOPIC_SIGNALS_ALERTS=market.signals.alerts

# Project storage roots
STORAGE_ROOT=./storage
BRONZE_PATH=./storage/bronze
SILVER_PATH=./storage/silver
GOLD_PATH=./storage/gold
CHECKPOINT_ROOT=./storage/checkpoints

# Binance public market stream defaults for later milestones
BINANCE_WS_BASE_URL=wss://stream.binance.com:9443/stream
CRYPTO_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT,XRPUSDT,ADAUSDT,DOGEUSDT,LINKUSDT,AVAXUSDT,MATICUSDT
BINANCE_STREAM_TYPES=trade,kline_1m,ticker

# Producer runtime settings
PRODUCER_CLIENT_ID=crypto-market-intelligence-producer
PRODUCER_SCHEMA_VERSION=1.0
PRODUCER_SOURCE=binance
PRODUCER_LOG_LEVEL=INFO
PRODUCER_PUBLISH_LOG_INTERVAL=1000
PRODUCER_RECONNECT_INITIAL_DELAY_SECONDS=1
PRODUCER_RECONNECT_MAX_DELAY_SECONDS=60
PRODUCER_KAFKA_ACKS=all
PRODUCER_KAFKA_LINGER_MS=50
PRODUCER_KAFKA_REQUEST_TIMEOUT_MS=30000
WEBSOCKET_PING_INTERVAL_SECONDS=20
WEBSOCKET_PING_TIMEOUT_SECONDS=60
WEBSOCKET_MAX_QUEUE=1024
